# Copy to .env. Do not commit .env.

# Required
MAL_CLIENT_ID=
ANIMEAPI_URL=https://animeapi.net
PASSWORD_HASH=

# Optional: stream proxy for 403 on some CDNs. Run `node scripts/stream-proxy.js`
# STREAM_PROXY_URL=http://localhost:3333/proxy

# Optional: dev-only static m3u8 to test player
# DEV_STREAM_URL=
# DEV_STREAM_REFERER=
# DEV_STREAM_ORIGIN=
# DEV_STREAM_USER_AGENT=
